{
  // ============================================================
  // DEFAULT ASP.NET CORE LOGGING CONFIGURATION
  // ============================================================
  // This configures the built-in Microsoft logging abstraction.
  // Serilog replaces the default logging provider through:
  // builder.Host.UseSerilog();

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ============================================================
  // SERILOG CONFIGURATION
  // ============================================================
  // Loaded in Program.cs through:
  // .ReadFrom.Configuration(builder.Configuration)

  "Serilog": {

    // Explicitly specifies the Serilog sink assemblies
    // used by this configuration.
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.MSSqlServer"
    ],

    // Minimum log levels.
    // Default = Information means Information, Warning,
    // Error and Critical logs will be processed.
    "MinimumLevel": {
      "Default": "Information",

      // Overrides reduce unnecessary framework-generated logs.
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },

    // Defines where Serilog writes the logs.
    "WriteTo": [
      {
        // Writes logs to the application console.
        "Name": "Console"
      },
      {
        // Writes logs to rolling log files.
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",

          // Creates a new log file every day.
          "rollingInterval": "Day"
        }
      },
      {
        // Writes structured application logs to SQL Server.
        "Name": "MSSqlServer",
        "Args": {

          // Refers to the connection string named
          // EnterpriseInventoryDb under ConnectionStrings.
          "connectionString": "EnterpriseInventoryDb",

          // Only Warning, Error and Critical logs are written
          // to SQL Server.
          // Information and Debug logs are excluded from SQL.
          "restrictedToMinimumLevel": "Warning",

          // SQL Server sink-specific configuration.
          "sinkOptionsSection": {
            "tableName": "Logs",

            // Automatically creates the Logs table
            // when it does not already exist.
            "autoCreateSqlTable": true
          }
        }
      }
    ]
  },

  // Allows requests from any host.
  "AllowedHosts": "*"
}